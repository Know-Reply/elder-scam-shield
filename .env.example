# Elder Scam Shield — Environment Variables
# Copy to .env and fill in your values

# Vertex AI (required) — run: gcloud auth application-default login
GOOGLE_GENAI_USE_VERTEXAI=TRUE
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=global

# Optional: Enable real Firestore (default: stubbed for demo)
# FIRESTORE_ENABLED=true
