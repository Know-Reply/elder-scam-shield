# Elder Scam Shield — Environment Variables
# Copy to .env and fill in your values

# Google Cloud project ID (required)
GOOGLE_CLOUD_PROJECT=your-project-id

# Vertex AI region — asia-northeast1 is Tokyo, closest to Japanese users
VERTEX_AI_LOCATION=asia-northeast1

# Firestore database — "(default)" uses the project's default database
FIRESTORE_DATABASE=(default)
